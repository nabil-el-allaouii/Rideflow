{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/RideFlow/browser",
  "devCommand": "npm start",
  "installCommand": "npm install",
  "framework": "angular",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://rideflow-backend.onrender.com/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://rideflow-xxx.vercel.app" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}